# Milvus RAG environment template for local development.
# Marketplace installs usually configure these values through Codex MCP settings.

# Required: Milvus connection and searchable text field.
MILVUS_RAG_URI=http://127.0.0.1:19530
MILVUS_RAG_COLLECTION=pages
MILVUS_RAG_TEXT_FIELD=text

# Optional: enable semantic Search by providing a vector field and embeddings endpoint.
MILVUS_RAG_VECTOR_FIELD=dense
MILVUS_RAG_EMBED_URL=http://127.0.0.1:8080/v1/embeddings

# Optional: Milvus authentication.
MILVUS_RAG_DB_NAME=
MILVUS_RAG_USER=
MILVUS_RAG_PASSWORD=
MILVUS_RAG_TOKEN=

# Optional: embedding request settings.
MILVUS_RAG_EMBED_MODEL=
MILVUS_RAG_EMBED_API_KEY=
MILVUS_RAG_METRIC=COSINE
MILVUS_RAG_EMBED_TIMEOUT_S=30

# Optional: append JSON-RPC debug logs to a file.
# MILVUS_RAG_DEBUG_LOG=D:/tmp/milvus-rag.log

# Helps avoid locale-related parsing issues on some Windows systems.
LANG=C
