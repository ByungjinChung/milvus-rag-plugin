# milvus-rag — 환경 변수 템플릿 (로컬 개발용).
# 이 파일을 `.env`로 복사해서 값을 채우면 서버 시작 시 python-dotenv가 자동 로드합니다.
# 마켓플레이스 설치 경로에서는 이 파일이 필요 없습니다 —
# 사용자 `~/.codex/config.toml`의 [mcp_servers.corpus.env] 블록에서 오버라이드합니다.
#
# 부모 프로세스 환경변수가 우선(override=False)이라
# 셸 export 값이 여기 설정을 이깁니다.

# =========================================================================
# 필수 (Milvus 접속 + 텍스트 필드)
# =========================================================================
MILVUS_RAG_URI=http://127.0.0.1:19530
MILVUS_RAG_COLLECTION=jedec_chunks
MILVUS_RAG_TEXT_FIELD=text

# =========================================================================
# 시맨틱 Search를 쓰려면 필수 (벡터 필드 + 임베딩 엔드포인트)
# =========================================================================
# 아래 두 개가 비어 있으면 Grep / Fetch 만 사용 가능. Search 호출은 에러 메시지.
MILVUS_RAG_VECTOR_FIELD=dense
MILVUS_RAG_EMBED_URL=http://127.0.0.1:8080/v1/embeddings

# =========================================================================
# 선택 (Milvus 인증 — 사용하는 것만 채움)
# =========================================================================
MILVUS_RAG_DB_NAME=
MILVUS_RAG_USER=
MILVUS_RAG_PASSWORD=
MILVUS_RAG_TOKEN=

# =========================================================================
# 선택 (임베딩 세부)
# =========================================================================
# 임베딩 서버가 model 필드를 요구할 때만 지정.
# BGE-M3를 로컬 llama.cpp로 띄운 경우: "bge-m3"
# OpenAI: "text-embedding-3-small" / "text-embedding-3-large"
MILVUS_RAG_EMBED_MODEL=

# OpenAI, Together 같은 클라우드용. 로컬은 빈 값.
MILVUS_RAG_EMBED_API_KEY=

# Milvus 인덱싱 시 지정된 metric — COSINE / IP / L2 중 하나.
MILVUS_RAG_METRIC=COSINE

# 임베딩 요청 타임아웃(초).
MILVUS_RAG_EMBED_TIMEOUT_S=30

# =========================================================================
# 진단 (선택)
# =========================================================================
# 파일 경로를 넣으면 모든 JSON-RPC 호출을 그 파일에 append.
# MILVUS_RAG_DEBUG_LOG=D:/tmp/milvus-rag.log

# 비영어 Windows 로케일에서 MCP 자동 재접속이 영어 에러 문자열 매칭이라
# 로케일을 강제 영어화합니다.
LANG=C
